# App
PORT=3100
APP_URL=http://localhost:3100
VITE_PUBLIC_APP_URL=https://a2a.ascotwm.com

# Supabase (service-role key — server only, never expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Asana
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_ID=
ASANA_A2A_PROJECT_ID=
ASANA_A2A_SECTION_ID=
ASANA_A2A_COMPLETE_DATE_FIELD_ID=

# OpenAI (voice dictation / transcription)
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_CHAT_MODEL=gpt-4o-mini

# Roles: comma-separated admin emails (delete/archive/reassign). Others can create/edit/assign.
A2A_ADMINS=

# Notifications: email this inbox when a brief is submitted. Blank disables.
A2A_NOTIFY_EMAIL=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Google Drive (handover PDF filing). Service-account JSON (single line) + parent folder.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
# Only for My Drive folders via domain-wide delegation; leave blank for Shared Drives.
GOOGLE_IMPERSONATE_SUBJECT=

# RTQ / External Sign-Up Intake API (send a client a Risk Questionnaire to e-sign)
AWM_SIGNUP_API_URL=
AWM_SIGNUP_API_KEY=
AWM_WEBHOOK_SECRET=
AWM_WEBHOOK_URL=

# SSO + session auth
SSO_SHARED_SECRET=
SSO_ISSUER=ascotwm.com
SSO_AUDIENCE=
SESSION_JWT_SECRET=
SESSION_TTL_HOURS=8

# Dev-only
DEV_USER_EMAIL=dev@ascotwm.com
DEV_USER_NAME=Local Dev
